{
  "name": "@DexQBit/frontend-security-audit",
  "version": "1.7.0",
  "description": "Shared security audit tool and GitHub Actions workflow for Next.js projects",
  "type": "module",
  "main": "src/security-audit.mjs",
  "bin": {
